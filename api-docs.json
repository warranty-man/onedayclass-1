      "/api/visitors/track": {
        "post": {
          "tags": [
            "Visitors"
          ],
          "summary": "방문자 집계 반영",
          "description": "현재 요청의 IP와 User-Agent를 기준으로 오늘 방문자를 집계하고, 오늘/누적 방문자 수를 반환합니다.",
          "operationId": "trackVisit",
          "responses": {
            "200": {
              "description": "집계 성공",
              "content": {
                "*/*": {
                  "schema": {
                    "$ref": "#/components/schemas/VisitorStatsResponse"
                  }
                }
              }
            }
          }
        }
      },
