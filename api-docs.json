      "/api/articles": {
        "get": {
          "tags": [
            "Articles"
          ],
          "summary": "글 목록 조회",
          "description": "글 목록을 페이지 단위로 조회합니다. 페이지 번호는 1부터 시작하며 size는 최대 10입니다.",
          "operationId": "findAllArticles",
          "parameters": [
            {
              "name": "page",
              "in": "query",
              "description": "조회할 페이지 번호. 1부터 시작합니다.",
              "required": false,
              "schema": {
                "type": "integer",
                "format": "int32",
                "default": 1
              },
              "example": 1
            },
            {
              "name": "size",
              "in": "query",
              "description": "페이지 크기. 최대 10입니다.",
              "required": false,
              "schema": {
                "type": "integer",
                "format": "int32",
                "default": 10
              },
              "example": 10
            }
          ],
          "responses": {
            "200": {
              "description": "조회 성공",
              "content": {
                "*/*": {
                  "schema": {
                    "$ref": "#/components/schemas/ArticlePageResponse"
